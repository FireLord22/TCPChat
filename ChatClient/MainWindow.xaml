<Window x:Class="ChatClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Гойдаграм" Height="680" Width="980" MinWidth="700" MinHeight="500"
        Background="#1C1C1E"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Цвета -->
        <SolidColorBrush x:Key="BgMain"     Color="#1C1C1E"/>
        <SolidColorBrush x:Key="BgPanel"    Color="#242426"/>
        <SolidColorBrush x:Key="BgItem"     Color="#2C2C2E"/>
        <SolidColorBrush x:Key="BgItemHov"  Color="#3A3A3C"/>
        <SolidColorBrush x:Key="BgItemSel"  Color="#3A3A3C"/>
        <SolidColorBrush x:Key="BgInput"    Color="#2C2C2E"/>
        <SolidColorBrush x:Key="Accent"     Color="#4A9EFF"/>
        <SolidColorBrush x:Key="TextPrim"   Color="#F2F2F7"/>
        <SolidColorBrush x:Key="TextSecond" Color="#8E8E93"/>
        <SolidColorBrush x:Key="Separator"  Color="#38383A"/>

        <!-- Стиль элемента списка чатов -->
        <Style x:Key="ChatListItem" TargetType="ListBoxItem">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrim}"/>
            <Setter Property="Padding"     Value="14,10"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderThickness="0" CornerRadius="6" Margin="4,2">
                            <ContentPresenter Margin="10,8"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgItemHov}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgItemSel}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопок -->
        <Style TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Padding"          Value="14,7"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль TextBox -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource BgInput}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrim}"/>
            <Setter Property="CaretBrush"      Value="{StaticResource TextPrim}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- шапка -->
            <RowDefinition Height="*"/>
            <!-- основной контент -->
        </Grid.RowDefinitions>

        <!-- ?? ШАПКА ?????????????????????????????????????????????????????????? -->
        <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource Separator}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип -->
                <TextBlock Grid.Column="0" Text="Гойдаграм"
                           Foreground="{StaticResource Accent}"
                           FontSize="17" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="0,0,24,0"/>

                <!-- Поля подключения (видны до входа) -->
                <StackPanel x:Name="AuthPanel" Grid.Column="1"
                            Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Сервер" Foreground="{StaticResource TextSecond}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="HostTextBox" Text="127.0.0.1" Width="110"/>
                    <TextBlock Text="Порт" Foreground="{StaticResource TextSecond}"
                               FontSize="12" VerticalAlignment="Center" Margin="10,0,6,0"/>
                    <TextBox x:Name="PortTextBox" Text="5000" Width="52"/>
                    <TextBlock Text="Логин" Foreground="{StaticResource TextSecond}"
                               FontSize="12" VerticalAlignment="Center" Margin="10,0,6,0"/>
                    <TextBox x:Name="NicknameTextBox" Width="90"/>
                    <TextBlock Text="Пароль" Foreground="{StaticResource TextSecond}"
                               FontSize="12" VerticalAlignment="Center" Margin="10,0,6,0"/>
                    <PasswordBox x:Name="PasswordBox" Width="90"
                                 Background="{StaticResource BgInput}"
                                 Foreground="{StaticResource TextPrim}"
                                 BorderThickness="0" Padding="10,7"
                                 FontSize="13" VerticalContentAlignment="Center"
                                 KeyDown="PasswordBox_KeyDown"/>
                    <Button x:Name="LoginButton" Content="Войти"
                            Margin="10,0,0,0" Click="LoginButton_Click"/>
                    <Button x:Name="RegisterButton" Content="Регистрация"
                            Background="{StaticResource BgItem}"
                            Foreground="{StaticResource Accent}"
                            Margin="6,0,0,0" Click="RegisterButton_Click"/>
                </StackPanel>

                <!-- Панель авторизованного пользователя (видна после входа) -->
                <StackPanel x:Name="LoggedInPanel" Grid.Column="1"
                            Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock x:Name="LoggedInLabel"
                               Foreground="{StaticResource TextSecond}"
                               FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock x:Name="AuthErrorLabel"
                               Foreground="#FF6B6B" FontSize="12"
                               VerticalAlignment="Center" Margin="16,0,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>

                <!-- Кнопка отключения -->
                <Button x:Name="DisconnectButton" Grid.Column="2"
                        Content="Выйти" Background="#3A3A3C"
                        IsEnabled="False" Margin="16,0,0,0"
                        Click="DisconnectButton_Click"/>
            </Grid>
        </Border>

        <!-- ?? ОСНОВНОЙ КОНТЕНТ ??????????????????????????????????????????????? -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" MinWidth="180" MaxWidth="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ?? ЛЕВАЯ ПАНЕЛЬ: список чатов ?? -->
            <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource Separator}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Поиск / заголовок -->
                    <Border Grid.Row="0" Padding="10,10,10,6">
                        <TextBlock Text="Чаты" Foreground="{StaticResource TextPrim}"
                                   FontSize="15" FontWeight="SemiBold"/>
                    </Border>

                    <!-- Список чатов -->
                    <ListBox x:Name="ChatListBox" Grid.Row="1"
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource ChatListItem}"
                             SelectionChanged="ChatListBox_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    </ListBox>

                    <!-- Кнопка создать группу -->
                    <Border Grid.Row="2" Padding="10,8"
                            BorderBrush="{StaticResource Separator}" BorderThickness="0,1,0,0">
                        <Button x:Name="NewGroupButton" Content="+ Новая группа"
                                Background="{StaticResource BgItem}"
                                Foreground="{StaticResource Accent}"
                                IsEnabled="False"
                                Click="NewGroupButton_Click"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ?? ПРАВАЯ ПАНЕЛЬ: чат ?? -->
            <Grid Grid.Column="1" Background="{StaticResource BgMain}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- заголовок чата -->
                    <RowDefinition Height="*"/>
                    <!-- сообщения -->
                    <RowDefinition Height="Auto"/>
                    <!-- ввод -->
                </Grid.RowDefinitions>

                <!-- Заголовок чата -->
                <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource Separator}" BorderThickness="0,0,0,1"
                        Padding="20,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="ChatTitleLabel"
                                       Text="Выберите чат"
                                       Foreground="{StaticResource TextPrim}"
                                       FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ChatSubtitleLabel"
                                       Text=""
                                       Foreground="{StaticResource TextSecond}"
                                       FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <!-- Кнопка инвайта в группу (видна только в групповом чате) -->
                        <Button x:Name="InviteButton" Grid.Column="1"
                                Content="Пригласить"
                                Background="{StaticResource BgItem}"
                                Foreground="{StaticResource Accent}"
                                Visibility="Collapsed" IsEnabled="False"
                                Click="InviteButton_Click"/>
                    </Grid>
                </Border>

                <!-- Сообщения -->
                <ScrollViewer x:Name="MessagesScroll" Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,12">
                    <StackPanel x:Name="MessagesPanel"/>
                </ScrollViewer>

                <!-- Плейсхолдер -->
                <TextBlock x:Name="PlaceholderText" Grid.Row="1"
                           Text="Выберите чат слева, чтобы начать переписку"
                           Foreground="{StaticResource TextSecond}"
                           FontSize="15" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- Плашка цензуры — поверх чата, снизу -->
                <Border x:Name="CensorBanner" Grid.Row="1"
                        VerticalAlignment="Bottom" HorizontalAlignment="Center"
                        Background="#4A3060" CornerRadius="8"
                        Padding="18,10" Margin="0,0,0,14"
                        Visibility="Collapsed" Opacity="0.95"
                        Panel.ZIndex="10">
                    <TextBlock Text="? Вы расстроили стражу"
                               Foreground="#D9B3FF" FontSize="13" FontWeight="SemiBold"/>
                </Border>

                <!-- Поле ввода -->
                <Border Grid.Row="2" Background="{StaticResource BgPanel}"
                        BorderBrush="{StaticResource Separator}" BorderThickness="0,1,0,0"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="MessageTextBox" Grid.Column="0"
                                 IsEnabled="False"
                                 KeyDown="MessageTextBox_KeyDown"/>
                        <Button x:Name="SendButton" Grid.Column="1"
                                Content="Отправить"
                                IsEnabled="False" Margin="10,0,0,0"
                                Click="SendButton_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
