<Window x:Class="ChatServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Чат — Сервер" Height="550" Width="700"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Порт:" VerticalAlignment="Center" FontSize="13"/>
            <TextBox x:Name="PortTextBox" Text="5000" Width="70"
                     VerticalAlignment="Center" FontSize="13" Padding="4"/>
            <Button x:Name="StartButton" Content="▶ Запустить"
                    Background="#27AE60" Foreground="White"
                    Margin="10,0,0,0" Click="StartButton_Click"/>
            <Button x:Name="StopButton" Content="■ Остановить"
                    Background="#E74C3C" Foreground="White"
                    Margin="8,0,0,0" IsEnabled="False" Click="StopButton_Click"/>
            <ToggleButton x:Name="CensorButton" Content="🛡 Цензура: ВКЛ"
                    Background="#8E44AD" Foreground="White"
                    Padding="12,6" FontSize="13" Cursor="Hand"
                    IsChecked="True"
                    Margin="16,0,0,0" Click="CensorButton_Click"/>
            <Border Background="#ECF0F1" CornerRadius="4" Padding="10,4" Margin="20,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Label Content="Активных клиентов:" FontSize="12" Padding="0"/>
                    <Label x:Name="ClientCountLabel" Content="0"
                           FontSize="12" FontWeight="Bold" Foreground="#2980B9" Padding="4,0,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Log Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <!-- Event Log -->
            <GroupBox Grid.Column="0" Header="Лог событий" Margin="0,0,8,0">
                <ListBox x:Name="LogListBox"
                         FontFamily="Consolas" FontSize="12"
                         Background="#1E1E1E" Foreground="#D4D4D4"
                         BorderThickness="0" Padding="4"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </GroupBox>

            <!-- Connected users -->
            <GroupBox Grid.Column="1" Header="Пользователи онлайн">
                <ListBox x:Name="UsersListBox"
                         FontSize="13"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>
            </GroupBox>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="8,4" Margin="0,8,0,0" CornerRadius="4">
            <Label x:Name="StatusLabel" Content="Сервер не запущен"
                   FontSize="12" Padding="0" Foreground="#7F8C8D"/>
        </Border>
    </Grid>
</Window>
